@{
    ViewData["Title"] = "Inicio";
}

<div class="container mt-5">

    <!-- HERO -->
    <div class="text-center">
        <h1 class="display-4 fw-bold text-primary">WinMovers</h1>
        <p class="lead">Sistema de gestión para servicios de mudanza y logística</p>

        <!-- BOTÓN PRINCIPAL -->
        <a href="/Dashboards/Index" class="btn btn-info text-white btn-lg mt-3">
            <i class="fas fa-chart-line"></i> Ir al Panel Administrativo
        </a>
    </div>

    <!-- SECCIÓN INFO -->
    <div class="row mt-5">

        <div class="col-md-4 text-center">
            <i class="fas fa-users fa-3x text-primary mb-3"></i>
            <h4>Clientes</h4>
            <p>Gestión completa de clientes registrados</p>
        </div>

        <div class="col-md-4 text-center">
            <i class="fas fa-truck fa-3x text-primary mb-3"></i>
            <h4>Mudanzas</h4>
            <p>Seguimiento de servicios en tiempo real</p>
        </div>

        <div class="col-md-4 text-center">
            <i class="fas fa-boxes fa-3x text-primary mb-3"></i>
            <h4>Inventario</h4>
            <p>Control de materiales y recursos</p>
        </div>

    </div>

</div>