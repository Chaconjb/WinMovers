@model IEnumerable<WinMovers.Models.Exportacion>
@{
    ViewData["Title"] = "Exportaciones";
}

<div class="form-header">
    <h2 class="content-title"><i class="fas fa-file-export"></i> Embarques de Exportación</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Nuevo Embarque</a>
</div>

<div class="form-card" style="margin-bottom:20px;">
    <form asp-action="Index" method="get">

        <div class="form-row three-cols">

            <div class="form-group">
                <label>Cliente</label>
                <input type="text"
                       name="cliente"
                       value="@ViewBag.Cliente"
                       class="form-control"
                       placeholder="Buscar por cliente" />
            </div>

            <div class="form-group">
                <label>Fecha</label>
                <input type="date"
                       name="fecha"
                       value="@ViewBag.Fecha"
                       class="form-control" />
            </div>

            <div class="form-group" style="align-self:end;">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                    Buscar
                </button>

                <a asp-action="Index" class="btn btn-secondary">
                    Limpiar
                </a>
            </div>

        </div>

    </form>
</div>

<div class="table-container">
    <table class="data-table">
        <thead>
            <tr>
                <th>Cliente</th>
                <th>Referencia</th>
                <th>Fecha</th>
                <th>Cajas</th>
                <th>Kilos</th>
                <th>Documentos WinMovers</th>
                <th>Documentos Otro Agente</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="no-data">No hay embarques registrados. <a asp-action="Create">Crear el primero</a>.</td></tr>
            }
            else
            {
                @foreach (var e in Model)
                {
                    var docsWM   = e.Documentos.Where(d => d.TipoChecklist == "WinMovers").ToList();
                    var docsOA   = e.Documentos.Where(d => d.TipoChecklist == "OtroAgente").ToList();
                    var wmOk     = docsWM.Count(d => d.Completado);
                    var oaOk     = docsOA.Count(d => d.Completado);

                    <tr>
                        <td>@e.NombreCliente</td>
                        <td>@(e.Referencia ?? "—")</td>
                        <td>@(e.Fecha?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td>@e.Cajas</td>
                        <td>@e.Kilos.ToString("N2")</td>
                        <td>
                            <span class="badge @(wmOk == docsWM.Count && docsWM.Count > 0 ? "badge-success" : "badge-warning")">
                                @wmOk / @docsWM.Count
                            </span>
                        </td>
                        <td>
                            <span class="badge @(oaOk == docsOA.Count && docsOA.Count > 0 ? "badge-success" : "badge-warning")">
                                @oaOk / @docsOA.Count
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit"
                               asp-route-id="@e.IdExportacion"
                               class="btn-icon edit"
                               title="Editar">
                                <i class="fas fa-pen"></i>
                            </a>
                            <a asp-action="Checklist" asp-route-id="@e.IdExportacion" class="btn-icon edit" title="Gestionar Checklist">
                                <i class="fas fa-tasks"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@e.IdExportacion" method="post" style="display:inline"
                                  onsubmit="return confirm('¿Eliminar este embarque?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-icon delete" title="Eliminar">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
