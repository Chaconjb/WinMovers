<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WinMovers</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Estilos -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- HEADER -->
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand fw-bold text-primary" asp-controller="Dashboards" asp-action="Index">
                    <i class="fas fa-truck-moving"></i> WinMovers
                </a>

                <!-- BOTÓN RESPONSIVE -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- MENÚ -->
                <div class="collapse navbar-collapse justify-content-between" id="menu">

                    <!-- IZQUIERDA -->
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboards" asp-action="Index">
                                <i class="fas fa-home"></i> Dashboard
                            </a>
                        </li>
                    </ul>

                    <!-- DERECHA (BOTÓN IMPORTANTE) -->
                    <div class="d-flex">
                        <a class="btn btn-info text-white" asp-controller="Dashboards" asp-action="Index">
                            <i class="fas fa-home"></i> Ir al Dashboard
                        </a>
                    </div>

                </div>

            </div>
        </nav>
    </header>

    <!-- CONTENIDO -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="text-center mt-5 mb-3 text-muted">
        © 2026 - WinMovers
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>