@model List<AvanceWinMovers.Models.OrdenTrabajo>

<div class="resultados-section" style="margin-top: 30px;">
    @if (ViewBag.Mensaje != null)
    {
        <div class="alert @(Model.Count > 0 ? "alert-info" : "alert-warning")" style="padding: 15px; border-radius: 4px; margin-bottom: 20px;">
            <i class="fas fa-info-circle"></i> @ViewBag.Mensaje
        </div>
    }

    @if (Model.Count > 0)
    {
        <table class="resultados-table" style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                    <th style="padding: 12px; text-align: left;">ID</th>
                    <th style="padding: 12px; text-align: left;">N. OT</th>
                    <th style="padding: 12px; text-align: left;">Cliente</th>
                    <th style="padding: 12px; text-align: left;">Contacto</th>
                    <th style="padding: 12px; text-align: left;">Fecha</th>
                    <th style="padding: 12px; text-align: center;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    var fechaVisible = cliente.fecha_servicio ?? cliente.fecha ?? cliente.fecha_creacion;
                    <tr style="border-bottom: 1px solid #dee2e6;">
                        <td style="padding: 12px;">@cliente.id_orden</td>
                        <td style="padding: 12px;">@cliente.numero_ot</td>
                        <td style="padding: 12px;">@cliente.nombre_cliente</td>
                        <td style="padding: 12px;">@(cliente.contacto ?? cliente.telefono_celular ?? "N/A")</td>
                        <td style="padding: 12px;">@fechaVisible.ToString("dd/MM/yyyy")</td>
                        <td style="padding: 12px; text-align: center;">
                            <button class="btn-historial" onclick="cargarHistorial('@cliente.nombre_cliente')" 
                                    style="padding: 6px 12px; background-color: #17a2b8; color: white; border: none; border-radius: 4px; cursor: pointer; margin-right: 5px;">
                                <i class="fas fa-history"></i> Historial
                            </button>
                            <button class="btn-detalles" onclick="cargarDetalles(@cliente.id_orden)" 
                                    style="padding: 6px 12px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;">
                                <i class="fas fa-eye"></i> Detalles
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <script>
            function cargarHistorial(nombreCliente) {
                fetch('@Url.Action("HistorialCliente", "Dashboards")' + '?nombreCliente=' + encodeURIComponent(nombreCliente))
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById('resultadosBusqueda').innerHTML = html;
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error al cargar el historial');
                    });
            }

            function cargarDetalles(idOrden) {
                fetch('@Url.Action("DetalleOrden", "Dashboards")' + '?id=' + idOrden)
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById('resultadosBusqueda').innerHTML = html;
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Error al cargar los detalles');
                    });
            }
        </script>
    }
</div>

<style>
    .resultados-table tr:hover {
        background-color: #f9f9f9;
    }
    
    .alert {
        border-radius: 4px;
    }
    
    .alert-info {
        background-color: #d1ecf1;
        border: 1px solid #bee5eb;
        color: #0c5460;
    }
    
    .alert-warning {
        background-color: #fff3cd;
        border: 1px solid #ffeeba;
        color: #856404;
    }
    
    .btn-historial:hover {
        background-color: #138496;
    }
    
    .btn-detalles:hover {
        background-color: #0056b3;
    }
</style>
