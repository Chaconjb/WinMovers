@model AvanceWinMovers.Models.Cotizacion

<h2>Editar Cotización</h2>

<form asp-action="EditarCotizacion" asp-controller="Dashboards" method="post">
    <input type="hidden" asp-for="id_cotizacion" />
    <div><label>Número</label><input asp-for="numero_cotizacion" class="form-control" /></div>
    <div><label>Cliente</label><input asp-for="nombre_cliente" class="form-control" /></div>
    <div><label>Origen</label><input asp-for="origen" class="form-control" /></div>
    <div><label>Destino</label><input asp-for="destino" class="form-control" /></div>
    <div><label>Monto</label><input asp-for="monto" type="number" step="0.01" class="form-control" /></div>
    <div><label>Estado</label><input asp-for="estado" class="form-control" /></div>
    <div><label>Fecha</label><input asp-for="fecha_cotizacion" type="date" class="form-control" /></div>
    <div><label>Descripción</label><textarea asp-for="descripcion" class="form-control"></textarea></div>
    <button type="submit" class="btn btn-primary">Guardar cambios</button>
</form>